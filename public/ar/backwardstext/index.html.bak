<style>/* mikaio.dev tools — single reusable stylesheet. Logical props for RTL. */
:root{
  --bg:#f7f8fa;--card:#fff;--ink:#1a1d24;--muted:#5b6472;--line:#e4e7ec;
  --brand:#2563eb;--brand-ink:#fff;--ok:#16a34a;--accent:#eef2ff;--radius:12px;
  --maxw:920px;--font:system-ui,-apple-system,"Segoe UI",Roboto,"Noto Sans",Arial,sans-serif;
}
@media (prefers-color-scheme:dark){
  :root{--bg:#0f1218;--card:#181c24;--ink:#e8eaed;--muted:#9aa4b2;--line:#2a303b;--accent:#1e2637;}
}
*{box-sizing:border-box}
html{font-family:var(--font);line-height:1.65;color:var(--ink);background:var(--bg);-webkit-text-size-adjust:100%}
body{margin:0}
a{color:var(--brand);text-decoration:none}
a:hover{text-decoration:underline}
h1,h2,h3{line-height:1.25;color:var(--ink)}
h1{font-size:clamp(1.6rem,4vw,2.2rem);margin:.2em 0 .3em}
h2{font-size:1.35rem;margin:1.6em 0 .5em}
h3{font-size:1.1rem;margin:1.2em 0 .4em}
p{margin:.7em 0}
code{background:var(--accent);padding:.1em .35em;border-radius:5px;font-size:.9em}

/* layout */
.site-head,.site-foot{max-width:var(--maxw);margin-inline:auto;padding:1rem 1.1rem;display:flex;flex-wrap:wrap;gap:.8rem;align-items:center;justify-content:space-between}
.site-foot{display:block;color:var(--muted);font-size:.9rem;border-top:1px solid var(--line);margin-top:2rem}
.brand{font-weight:700;font-size:1.15rem;color:var(--ink)}
.tool-main,.home-main,.glossary-main{max-width:var(--maxw);margin-inline:auto;padding:0 1.1rem 2rem}
.crumbs{color:var(--muted);font-size:.85rem;margin:.3rem 0 1rem}
.lead{color:var(--muted);font-size:1.08rem;margin-bottom:1.4rem}

/* language switcher */
.lang-switch{list-style:none;display:flex;flex-wrap:wrap;gap:.5rem;margin:0;padding:0;font-size:.85rem}
.lang-switch a{padding:.15rem .5rem;border:1px solid var(--line);border-radius:999px;color:var(--muted)}
.lang-switch a[aria-current="true"]{background:var(--brand);color:var(--brand-ink);border-color:var(--brand)}
.lang-foot{margin-top:2rem}

/* widget / calculator card */
.widget{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:1.3rem;box-shadow:0 1px 3px rgba(0,0,0,.05);margin-bottom:1.8rem}
.field{margin:.7rem 0}
.field label{display:block;font-weight:600;font-size:.92rem;margin-bottom:.3rem}
input,select,textarea,button{font:inherit;color:inherit}
input[type=number],input[type=text],input[type=date],input[type=datetime-local],select,textarea{
  width:100%;padding:.6rem .7rem;background:var(--bg);border:1px solid var(--line);border-radius:8px}
textarea{min-height:120px;resize:vertical}
.row{display:flex;gap:.8rem;flex-wrap:wrap}
.row>.field{flex:1;min-width:140px}
.btn{display:inline-block;cursor:pointer;background:var(--brand);color:var(--brand-ink);border:0;border-radius:8px;padding:.6rem 1.1rem;font-weight:600}
.btn:hover{filter:brightness(1.05)}
.btn.secondary{background:var(--accent);color:var(--ink)}
.result{margin-top:1rem;padding:1rem;background:var(--accent);border-radius:8px;font-size:1.05rem}
.result .big{font-size:2rem;font-weight:700;display:block}
.hint{color:var(--muted);font-size:.85rem}
.copy-ok{color:var(--ok);font-weight:600}

/* content prose */
.content{font-size:1.02rem}
.content h2{border-top:1px solid var(--line);padding-top:1.2rem}
.content ul,.content ol{padding-inline-start:1.4rem}
.faq dt{font-weight:600;margin-top:1rem}
.faq dd{margin-inline-start:0;color:var(--muted)}

/* home grid */
.cat{margin:2rem 0}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:.9rem}
.tool-card{display:flex;flex-direction:column;gap:.25rem;background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:1rem;color:var(--ink)}
.tool-card:hover{border-color:var(--brand);text-decoration:none}
.tool-ico{font-size:1.4rem}
.tool-name{font-weight:600}
.tool-desc{color:var(--muted);font-size:.85rem}

/* coin toss */
#coin{text-align:center}
.coin-face{font-size:4.5rem;line-height:1;display:inline-block;margin:.4rem 0}
.coin-face.spin{animation:coin-spin .6s linear}
@keyframes coin-spin{0%{transform:rotateX(0)}100%{transform:rotateX(1440deg)}}
.coin-tally{display:flex;gap:1.5rem;justify-content:center;margin-top:1rem;color:var(--muted);font-size:.9rem}
.coin-tally b{color:var(--ink);font-size:1.2rem;display:block}

/* magic 8 ball */
#m8{text-align:center}
#m8-ball{width:150px;height:150px;border-radius:50%;margin:0 auto;background:radial-gradient(circle at 35% 30%,#555,#000 70%);display:flex;align-items:center;justify-content:center;color:#fff}
#m8-ball.spin{animation:coin-spin .5s linear}
#m8-ball .win{width:70px;height:70px;border-radius:50%;background:#1e40af;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700}
#m8-answer{min-height:1.6em;margin-top:1rem;font-weight:600;font-size:1.15rem}

/* glossary table */
.glossary{width:100%;border-collapse:collapse;font-size:.95rem}
.glossary th,.glossary td{text-align:start;padding:.55rem .6rem;border-bottom:1px solid var(--line)}
.glossary .lg a{margin-inline-end:.35rem;font-size:.8rem}
