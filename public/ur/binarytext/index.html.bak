<style>/* mikaio.dev tools — single reusable stylesheet. Logical props for RTL. */
:root{
  --bg:#f7f8fa;--card:#fff;--ink:#1a1d24;--muted:#5b6472;--line:#e4e7ec;
  --brand:#2563eb;--brand-ink:#fff;--ok:#16a34a;--accent:#eef2ff;--radius:12px;
  --maxw:920px;--font:system-ui,-apple-system,"Segoe UI",Roboto,"Noto Sans",Arial,sans-serif;
}
@media (prefers-color-scheme:dark){
  :root{--bg:#0f1218;--card:#181c24;--ink:#e8eaed;--muted:#9aa4b2;--line:#2a303b;--accent:#1e2637;}
}
*{box-sizing:border-box}
html{font-family:var(--font);line-height:1.65;color:var(--ink);background:var(--bg);-webkit-text-size-adjust:100%}
body{margin:0}
a{color:var(--brand);text-decoration:none}
a:hover{text-decoration:underline}
h1,h2,h3{line-height:1.25;color:var(--ink)}
h1{font-size:clamp(1.6rem,4vw,2.2rem);margin:.2em 0 .3em}
h2{font-size:1.35rem;margin:1.6em 0 .5em}
h3{font-size:1.1rem;margin:1.2em 0 .4em}
p{margin:.7em 0}
code{background:var(--accent);padding:.1em .35em;border-radius:5px;font-size:.9em}

/* layout */
.site-head,.site-foot{max-width:var(--maxw);margin-inline:auto;padding:1rem 1.1rem;display:flex;flex-wrap:wrap;gap:.8rem;align-items:center;justify-content:space-between}
.site-foot{display:block;color:var(--muted);font-size:.9rem;border-top:1px solid var(--line);margin-top:2rem}
.brand{font-weight:700;font-size:1.15rem;color:var(--ink)}
.tool-main,.home-main,.glossary-main{max-width:var(--maxw);margin-inline:auto;padding:0 1.1rem 2rem}
.crumbs{color:var(--muted);font-size:.85rem;margin:.3rem 0 1rem}
.lead{color:var(--muted);font-size:1.08rem;margin-bottom:1.4rem}

/* language switcher */
.lang-switch{list-style:none;display:flex;flex-wrap:wrap;gap:.5rem;margin:0;padding:0;font-size:.85rem}
.lang-switch a{padding:.15rem .5rem;border:1px solid var(--line);border-radius:999px;color:var(--muted)}
.lang-switch a[aria-current="true"]{background:var(--brand);color:var(--brand-ink);border-color:var(--brand)}
.lang-foot{margin-top:2rem}

/* widget / calculator card */
.widget{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:1.3rem;box-shadow:0 1px 3px rgba(0,0,0,.05);margin-bottom:1.8rem}
.field{margin:.7rem 0}
.field label{display:block;font-weight:600;font-size:.92rem;margin-bottom:.3rem}
input,select,textarea,button{font:inherit;color:inherit}
input[type=number],input[type=text],input[type=date],input[type=datetime-local],select,textarea{
  width:100%;padding:.6rem .7rem;background:var(--bg);border:1px solid var(--line);border-radius:8px}
textarea{min-height:120px;resize:vertical}
.row{display:flex;gap:.8rem;flex-wrap:wrap}
.row>.field{flex:1;min-width:140px}
.btn{display:inline-block;cursor:pointer;background:var(--brand);color:var(--brand-ink);border:0;border-radius:8px;padding:.6rem 1.1rem;font-weight:600}
.btn:hover{filter:brightness(1.05)}
.btn.secondary{background:var(--accent);color:var(--ink)}
.result{margin-top:1rem;padding:1rem;background:var(--accent);border-radius:8px;font-size:1.05rem}
.result .big{font-size:2rem;font-weight:700;display:block}
.hint{color:var(--muted);font-size:.85rem}
.copy-ok{color:var(--ok);font-weight:600}

/* content prose */
.content{font-size:1.02rem}
.content h2{border-top:1px solid var(--line);padding-top:1.2rem}
.content ul,.content ol{padding-inline-start:1.4rem}
.faq dt{font-weight:600;margin-top:1rem}
.faq dd{margin-inline-start:0;color:var(--muted)}

/* home grid */
.cat{margin:2rem 0}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:.9rem}
.tool-card{display:flex;flex-direction:column;gap:.25rem;background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:1rem;color:var(--ink)}
.tool-card:hover{border-color:var(--brand);text-decoration:none}
.tool-ico{font-size:1.4rem}
.tool-name{font-weight:600}
.tool-desc{color:var(--muted);font-size:.85rem}

/* coin toss */
#coin{text-align:center}
.coin-face{font-size:4.5rem;line-height:1;display:inline-block;margin:.4rem 0}
.coin-face.spin{animation:coin-spin .6s linear}
@keyframes coin-spin{0%{transform:rotateX(0)}100%{transform:rotateX(1440deg)}}
.coin-tally{display:flex;gap:1.5rem;justify-content:center;margin-top:1rem;color:var(--muted);font-size:.9rem}
.coin-tally b{color:var(--ink);font-size:1.2rem;display:block}

/* magic 8 ball */
#m8{text-align:center}
#m8-ball{width:150px;height:150px;border-radius:50%;margin:0 auto;background:radial-gradient(circle at 35% 30%,#555,#000 70%);display:flex;align-items:center;justify-content:center;color:#fff}
#m8-ball.spin{animation:coin-spin .5s linear}
#m8-ball .win{width:70px;height:70px;border-radius:50%;background:#1e40af;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700}
#m8-answer{min-height:1.6em;margin-top:1rem;font-weight:600;font-size:1.15rem}

/* glossary table */
.glossary{width:100%;border-collapse:collapse;font-size:.95rem}
.glossary th,.glossary td{text-align:start;padding:.55rem .6rem;border-bottom:1px solid var(--line)}
.glossary .lg a{margin-inline-end:.35rem;font-size:.8rem}
</style>
<script type="application/ld+json">[{"@context":"https://schema.org","@type":"WebApplication","name":"Binary Translator — convert text to binary and back","url":"https://mikaio.dev/ur/binarytext/","applicationCategory":"UtilitiesApplication","operatingSystem":"Any","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"inLanguage":"ur","description":"Free binary translator. Convert any text to binary code and decode binary back to text, with full Unicode support, instantly and privately in your browser."},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"mikaio.dev","item":"https://mikaio.dev/ur/"},{"@type":"ListItem","position":2,"name":"Binary Translator","item":"https://mikaio.dev/ur/binarytext/"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How is text turned into binary?","acceptedAnswer":{"@type":"Answer","text":"Each character is encoded as one or more bytes using the UTF-8 standard, and each byte is written as eight binary digits (bits). Groups are separated by spaces so the result is easy to read and to decode again."}},{"@type":"Question","name":"Can it handle accents and emoji?","acceptedAnswer":{"@type":"Answer","text":"Yes. Because it uses UTF-8, letters with accents, non-Latin scripts and emoji are converted correctly into their multi-byte binary form and decoded back without loss."}},{"@type":"Question","name":"To decode, how should the binary be formatted?","acceptedAnswer":{"@type":"Answer","text":"Paste groups of eight bits separated by spaces, such as 01001000 01101001. Extra spaces are ignored, and anything that is not a 0 or 1 group is skipped."}}]}]</script>
</head>
<body>
<header class="site-head"><a class="brand" href="/ur/">mikaio.dev</a>
  <nav class="site-nav" aria-label="سائٹ نیویگیشن">
    <ul class="lang-switch"><li><a hreflang="en" lang="en" href="/en/">English</a></li><li><a hreflang="zh" lang="zh" href="/zh/">中文</a></li><li><a hreflang="hi" lang="hi" href="/hi/">हिन्दी</a></li><li><a hreflang="es" lang="es" href="/es/">Español</a></li><li><a hreflang="fr" lang="fr" href="/fr/">Français</a></li><li><a hreflang="ar" lang="ar" href="/ar/">العربية</a></li><li><a hreflang="bn" lang="bn" href="/bn/">বাংলা</a></li><li><a hreflang="pt" lang="pt" href="/pt/">Português</a></li><li><a hreflang="ru" lang="ru" href="/ru/">Русский</a></li><li><a hreflang="ur" lang="ur" aria-current="true" href="/ur/">اردو</a></li></ul>
  </nav></header>
<main class="tool-main">
  <nav class="crumbs" aria-label="Breadcrumb"><a href="/ur/">ہوم</a> › <span>Binary Translator</span></nav>
  <h1>Binary Translator</h1>
  <p class="lead">Type text and tap &#39;To binary&#39; to see its binary code, or paste binary and tap &#39;To text&#39; to decode it. Works with any language.</p>
  <section class="widget" id="tool"><div id="bin"><div class="field"><label for="bin-input">Text or binary</label><textarea id="bin-input" placeholder="Type text, or paste binary like 01001000…"></textarea></div><div class="cc-btns row"><button type="button" class="btn" data-op="encode">To binary</button><button type="button" class="btn" data-op="decode">To text</button></div><div class="field"><label for="bin-output">Result</label><textarea id="bin-output" readonly></textarea></div><button type="button" class="btn secondary" data-copy="#bin-output" data-copied="Copied!">Copy result</button></div></section>
  <article class="content">
    <h2>روزمرہ متن اور خالص بائنری کے درمیان ترجمہ</h2>
<p>اصل میں، آپ کا ٹائپ کیا ہوا ہر حرف، ہندسہ، خالی جگہ اور ایموجی کمپیوٹر کے اندر ایک اور صفر کی لڑی کے طور پر محفوظ ہوتا ہے۔ یہی بائنری ہے — بیس-2 نمبر سسٹم جسے تمام ڈیجیٹل آلات آخرکار استعمال کرتے ہیں۔ یہ بائنری مترجم آپ کو ان دونوں دنیاؤں کے درمیان آزادانہ آنے جانے دیتا ہے: عام متن ٹائپ کریں اور اسے اس کی نمائندگی کرنے والے بائنری کوڈ میں بدل دیں، یا ایک اور صفر کا سلسلہ پیسٹ کریں اور اسے واپس پڑھنے کے قابل متن میں ڈی کوڈ کر لیں۔ یہ کسی بھی زبان اور یہاں تک کہ ایموجی کے ساتھ بھی کام کرتا ہے، اور یہ سب کچھ آپ کے براؤزر کے اندر ہوتا ہے، چنانچہ تبدیلی فوری ہے اور آپ کا درج کردہ کچھ بھی کبھی اپلوڈ نہیں ہوتا۔</p>
<p>استعمال کرنا سیدھا سادہ ہے۔ خانے میں اپنا متن ٹائپ یا پیسٹ کریں، پھر &quot;بائنری میں تبدیل کریں&quot; پر تھپکی دیں تاکہ نیچے آٹھ آٹھ ہندسوں کے صاف ستھرے گروپوں میں بائنری ورژن نظر آ جائے۔ الٹی سمت جانے کے لیے، خانے میں بائنری کوڈ پیسٹ کریں اور &quot;متن میں تبدیل کریں&quot; پر تھپکی دیں تاکہ یہ واپس الفاظ میں ڈی کوڈ ہو جائے۔ کاپی بٹن نتیجہ آپ کے کلپ بورڈ میں رکھ دیتا ہے، جہاں چاہیں پیسٹ کرنے کے لیے تیار۔</p>
<h2>متن بائنری کیسے بنتا ہے</h2>
<p>کمپیوٹر حروف کو براہِ راست محفوظ نہیں کرتے؛ وہ ہندسے محفوظ کرتے ہیں، اور وہ ہندسے بائنری میں لکھتے ہیں۔ کسی حرف اور اس کے ہندسے کے درمیان تعلق ایک کریکٹر انکوڈنگ طے کرتی ہے، اور جدید معیار کو UTF-8 کہا جاتا ہے۔ UTF-8 میں، انگریزی کا کوئی عام حرف ایک ہی بائٹ لیتا ہے — آٹھ بٹ، یا آٹھ بائنری ہندسے۔ مثال کے طور پر بڑا حرف &quot;A&quot; عدد 65 ہے، جو بائنری میں 01000001 بنتا ہے۔ ان میں سے کئی بائٹس کو، ہر حرف کے لیے ایک، جوڑ دیں تو آپ کے پاس پورے پیغام کی بائنری نمائندگی آ جاتی ہے۔ یہ مترجم ہر بائٹ کو اس کے مکمل آٹھ ہندسوں والے گروپ کی صورت میں لکھتا ہے اور گروپوں کو خالی جگہوں سے الگ کرتا ہے، جو بائنری متن دکھانے کا معمول کا، پڑھنے کے قابل انداز ہے اور اسے دوبارہ ڈی کوڈ کرنا آسان بناتا ہے۔</p>
<p>بنیادی انگریزی حروف سے آگے کے حروف — زیر و زبر والے حروف، دوسرے حروفِ تہجی، علامتیں اور ایموجی — کو ایک سے زیادہ بائٹ درکار ہوتے ہیں، اور UTF-8 ان کے لیے دو، تین یا چار بائٹس استعمال کر کے یہ کام خوش اسلوبی سے کرتا ہے۔ مترجم بھی وہی اصول اپناتا ہے، چنانچہ یہ حروف درست طریقے سے کئی آٹھ بٹ گروپوں میں تبدیل ہوتے ہیں اور ڈی کوڈ کرنے پر بالکل درست طریقے سے دوبارہ جڑ جاتے ہیں۔ یہی وجہ ہے کہ یہ ٹول کسی دوسری زبان کے پیغام یا ایموجی کی لائن کے لیے بھی اتنا ہی اچھا کام کرتا ہے جتنا سادہ انگریزی کے لیے۔</p>
<h2>بائنری کو واپس متن میں ڈی کوڈ کرنا</h2>
<p>بائنری سے متن کی طرف جانا اسی عمل کو الٹ دیتا ہے۔ مترجم آپ کے ان پٹ کو آٹھ آٹھ بٹ کے گروپوں میں پڑھتا ہے، ہر گروپ کو واپس اس کی بائٹ قدر میں بدلتا ہے، اور پھر بائٹس کے سلسلے کو UTF-8 کے طور پر تشریح کر کے اصل حروف دوبارہ بناتا ہے۔ اس کے کام کرنے کے لیے، بائنری کو آٹھ آٹھ ہندسوں کے گروپوں میں ترتیب دیا جانا چاہیے، ترجیحاً خالی جگہوں سے الگ، جیسے 01001000 01101001۔ یہ ٹول اضافی خالی جگہ کے معاملے میں لچکدار ہے، اور جو کچھ ایک درست اور صفر کا گروپ نہ ہو، اسے سرے سے چھوڑ دیتا ہے، چنانچہ کوئی بھٹکا ہوا حرف پوری ڈی کوڈنگ کو نہیں توڑتا۔</p>
<p>یہ دو طرفہ صلاحیت مترجم کو محض ایک تفریح کی بجائے واقعی کارآمد بناتی ہے۔ آپ کوئی پیغام انکوڈ کر کے بائنری کسی کے ساتھ بانٹ سکتے ہیں، اور وہ اسے واپس پیسٹ کر کے پڑھ سکتا ہے — ایک سادہ، کم تکنیکی طریقہ کہ کوئی نوٹ بھیجا جائے جو اس شخص کو محض بے معنی لگے جسے یہ اندازہ نہ ہو کہ یہ دراصل متن ہے۔</p>
<h2>لوگ متن کو بائنری میں کیوں بدلتے ہیں</h2>
<p>سب سے عام وجہ سیکھنا ہے۔ بائنری وہیں سے شروع ہوتا ہے جہاں سے یہ سمجھنے کا مطالعہ شروع ہوتا ہے کہ کمپیوٹر کیسے کام کرتے ہیں، اور اپنا نام اور صفر میں بدلتا دیکھنا ایک تصوراتی خیال کو اچانک ٹھوس بنا دیتا ہے۔ طلبہ اور متجسس نئے سیکھنے والے اس جیسے مترجم کو مشقیں جانچنے، مختلف حروف مختلف بائٹ پیٹرن سے کیسے جڑتے ہیں یہ دیکھنے، اور یہ سمجھنے کے لیے استعمال کرتے ہیں کہ روزانہ استعمال ہونے والے سافٹ ویئر کے پیچھے اصل میں کیا ہو رہا ہے۔ استاد اسے کلاس سے ہاتھ سے تبدیلی کروائے بغیر کریکٹر انکوڈنگ دکھانے کے لیے استعمال کرتے ہیں۔</p>
<p>اس کا ایک تفریحی پہلو بھی ہے۔ بائنری متن خفیہ پیغامات لکھنے، کسی نرڈی پروفائل کو سجانے، یا دوستوں کے حل کرنے کے لیے کوئی معمہ بنانے کا ایک مقبول طریقہ ہے۔ چونکہ نتیجہ ایک اور صفر پر مشتمل حقیقی متن ہے، اسے کسی بایو، پیغام یا تبصرے میں کاپی کیا جا سکتا ہے۔ اور جو لوگ پیشہ ورانہ طور پر کمپیوٹرز کے ساتھ کام کرتے ہیں، ان کے لیے متن کے کسی ٹکڑے کی بائنری یا بائٹ قدروں پر ایک نظر ڈال لینا کبھی کبھار ایک کارآمد ڈی بگنگ ترکیب ثابت ہوتا ہے، خاص طور پر جب کوئی بھٹکا ہوا یا غیرمرئی حرف مسئلہ پیدا کر رہا ہو۔</p>
<h2>عددوں کو سمجھنا</h2>
<p>متن کو بائنری میں دیکھنا یہ سراہنے کا بھی ایک اچھا طریقہ ہے کہ معلومات کیسے جمع ہوتی جاتی ہے۔ عام انگریزی کا ہر حرف آٹھ بٹ بن جاتا ہے، چنانچہ ایک مختصر جملہ جلد ہی ہندسوں کی لمبی قطار بن جاتا ہے — ایک واضح یاد دہانی کہ تھوڑا سا متن بھی نیچے کہیں ایک اور صفر کی حیران کن تعداد رکھتا ہے۔ یہ یہ بھی دکھاتا ہے کہ فائل کے سائز اسی طرح کیوں ناپے جاتے ہیں: ایک بائٹ وہی آٹھ بٹ ہے، ایک کلوبائٹ ان میں سے تقریباً ایک ہزار ہے، اور اسی طرح آگے۔ چند الفاظ کو تبدیل کر کے گروپ گننا ڈیجیٹل ڈیٹا کے پیمانے کا ایک ٹھوس احساس دلاتا ہے۔</p>
<h2>نجی، فوری اور مفت</h2>
<p>نہ رجسٹریشن، نہ خرچہ، نہ راستے میں کوئی اشتہار۔ پورا مترجم کوڈ کا ایک چھوٹا سا ٹکڑا ہے جو آپ کے اپنے آلے پر چلتا ہے، یہی وجہ ہے کہ یہ تھپکی دیتے ہی تبدیل ہو جاتا ہے اور انٹرنیٹ کے بغیر بھی کام کرتا رہتا ہے۔ آپ کا درج کردہ کچھ بھی اپلوڈ، محفوظ یا بانٹا نہیں جاتا؛ آپ کا متن اور اس کی بائنری شکل صرف آپ کی اسکرین پر موجود ہوتے ہیں اور صفحہ دوبارہ لوڈ ہوتے ہی غائب ہو جاتے ہیں۔</p>
<p>استعمال کرنے کے لیے، اپنا متن ٹائپ یا پیسٹ کریں اور &quot;بائنری میں تبدیل کریں&quot; پر تھپکی دیں، یا بائنری پیسٹ کریں اور &quot;متن میں تبدیل کریں&quot; پر تھپکی دیں۔ بٹن سے نتیجہ کاپی کریں، اور جتنی بار چاہیں آگے پیچھے سوئچ کریں — مترجم دونوں سمتوں میں کسی بھی زبان، علامت یا ایموجی کو صاف ستھرے انداز میں سنبھال لیتا ہے۔</p>
    <section class="faq"><h2>Binary translator FAQ</h2><dl><dt>How is text turned into binary?</dt><dd>Each character is encoded as one or more bytes using the UTF-8 standard, and each byte is written as eight binary digits (bits). Groups are separated by spaces so the result is easy to read and to decode again.</dd><dt>Can it handle accents and emoji?</dt><dd>Yes. Because it uses UTF-8, letters with accents, non-Latin scripts and emoji are converted correctly into their multi-byte binary form and decoded back without loss.</dd><dt>To decode, how should the binary be formatted?</dt><dd>Paste groups of eight bits separated by spaces, such as 01001000 01101001. Extra spaces are ignored, and anything that is not a 0 or 1 group is skipped.</dd></dl></section>
  </article>
