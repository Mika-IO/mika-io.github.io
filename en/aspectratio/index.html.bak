  <h1>Aspect Ratio Calculator</h1>
  <p class="lead">Enter any width and height to instantly see the simplified aspect ratio and scale it to new dimensions.</p>
  <section class="widget" id="tool"><form id="tool-form" autocomplete="off">
  <div class="ar-section">
    <h3 class="ar-section-title">Simplify Ratio</h3>
    <div class="ar-row">
      <div class="ar-field">
        <label for="ar-width">Width</label>
        <input type="number" id="ar-width" min="1" placeholder="e.g. 1920" />
      </div>
      <span class="ar-sep">×</span>
      <div class="ar-field">
        <label for="ar-height">Height</label>
        <input type="number" id="ar-height" min="1" placeholder="e.g. 1080" />
